// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required, email format)
//   - displayName: string (required)
//   - points: number (required)
//   - rank: string (required, enum: worm, eagle, tiger, lion, dragon)
//   - role: string (required, enum: student, teacher)
//   - lastActive: number
//   - isOnline: boolean
//
// Collection: profiles
// Document ID: {userId}
// Fields: Same as users, but public for leaderboard
//
// Collection: challenges
// Document ID: {challengeId}
// Fields:
//   - id: string
//   - challengerId: string
//   - challengedId: string
//   - status: string (pending, accepted, declined, completed, cancelled, playing)
//   - timestamp: number
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' ||
         request.auth.token.email == "dalinadjib1990@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'points', 'rank', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.points is number &&
             data.rank in ['worm', 'eagle', 'tiger', 'lion', 'dragon'] &&
             data.role in ['student', 'teacher'];
    }

    function isValidChallenge(data) {
      return data.keys().hasAll(['id', 'challengerId', 'challengedId', 'status', 'timestamp']) &&
             data.id is string &&
             data.challengerId is string &&
             data.challengedId is string &&
             data.status in ['pending', 'accepted', 'declined', 'completed', 'cancelled', 'playing'] &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.challengerId || 
        request.auth.uid == resource.data.challengedId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidChallenge(request.resource.data) && 
                      (request.auth.uid == request.resource.data.challengerId || isAdmin());
      allow update: if isAuthenticated() && isValidChallenge(request.resource.data) && (
        request.auth.uid == resource.data.challengerId || 
        request.auth.uid == resource.data.challengedId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
